import hmac
import hashlib

# 1. 我们的绝对机密（必须和 Java 里写的一模一样）
secret_key = b"YooMoney_Secret_Key_2026"

# 2. 你的原始 JSON 订单数据
# 注意：连一个空格都不能差！必须和你 curl 里发的一模一样！
payload = b'{"order_id": "JP2220", "amount": 720, "status": "SUCCESS"}'

# 3. 召唤 HMAC-SHA256 粉碎机
signature = hmac.new(secret_key, payload, hashlib.sha256).hexdigest()

print("=======================================")
print("⚠️ 锻造成功的 X-Signature 数字指纹 ⚠️")
print(signature)
print("=======================================")
